    {
      "cell_type": "markdown",
      "source": [
        "## Acquiring Urban Data from OSM\n",
        "\n",
        "LEARNING OBJECTIVES\n",
        "- Pull administrative boundaries at multiple levels\n",
        "- Extract points of interest - hospitals, schools and markets\n",
        "- Extract polygon features - parks, leisure and water bodies\n",
        "- Understand OSM tags\n",
        "- Visualization\n"
      ],
      "metadata": {
        "id": "GWikyt-qZP4X"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "!pip install -q osmnx geopandas contextily folium mapclassify"
      ],
      "metadata": {
        "id": "hoWOeo4ti8aC"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import warnings\n",
        "warnings.filterwarnings('ignore')"
      ],
      "metadata": {
        "id": "QkdfXaJajkbt"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import osmnx as ox\n",
        "import geopandas as gpd\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.patches as mpatches\n",
        "import contextily as cx\n",
        "import folium\n",
        "from pathlib import Path"
      ],
      "metadata": {
        "id": "-k3QFm1YjyuA"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# CONFIGURATION\n",
        "study_area = \"Accra, Ghana\"\n",
        "crs_wgs84 = \"EPSG:4326\"\n",
        "crs_mercator = \"EPSG:3857\"\n",
        "crs_utm = \"EPSG:32630\"\n",
        "dark_bg = \"#0e1117\"\n",
        "amenity_color = \"#00e5ff\""
      ],
      "metadata": {
        "id": "wBtRIM8LkMlh"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# FOLDERS\n",
        "data_dir = Path('data')\n",
        "output_dir = Path('outputs')\n",
        "figures_dir = Path(output_dir / \"figures\")\n",
        "for d in [data_dir, output_dir, figures_dir]:\n",
        "  d.mkdir(parents = True, exist_ok=True)"
      ],
      "metadata": {
        "id": "3Je1KiSokwbt"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "## OSM TAGS DICTIONARIES\n",
        "amenity_tags = {\n",
        "    \"amenity\":[\n",
        "        \"hospital\", \"clinic\", \"pharmacy\",\n",
        "        \"school\", \"university\", \"library\",\n",
        "        \"marketplace\", \"bank\", \"atm\",\n",
        "        \"police\", \"fire_station\",\n",
        "        \"place_of_worship\", \"restaurant\",\"fuel\"\n",
        "    ]\n",
        "}\n",
        "\n",
        "\n",
        "leisure_tags = {\n",
        "    'leisure':[\n",
        "        \"park\", 'playground', 'sports_center',\n",
        "        'garden', 'stadium'\n",
        "    ]\n",
        "}\n",
        "\n",
        "print(f\"Study area: {study_area}\")"
      ],
      "metadata": {
        "id": "I_oZq-y9lKMj"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "## ADMINISTRATIVE BOUNDARY\n",
        "\n",
        "boundary = ox.geocode_to_gdf(study_area)"
      ],
      "metadata": {
        "id": "dduQJIsTl-Bx"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(f\"{study_area}-> {boundary.geometry.iloc[0].geom_type}\")"
      ],
      "metadata": {
        "id": "14TJ0_kcmKwk"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(f\"Bounding Box: {boundary.total_bounds}\")"
      ],
      "metadata": {
        "id": "6Iawy_BymZy4"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "### POINTS OF INTEREST(POIS)\n",
        "OSMNX returns mixed geometry types. We convert everything to point geometry (centroid) for consistent mapping"
      ],
      "metadata": {
        "id": "EBZlRvXWmgFT"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Pulling amenities\n",
        "amenities = ox.features_from_place(study_area, tags=amenity_tags)\n",
        "len(amenities)"
      ],
      "metadata": {
        "id": "i6Y61Et1m8Yh"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Unify to point geometry for mapping\n",
        "\n",
        "amenities_pts = amenities.copy()\n",
        "amenities_pts['geometry']  = amenities_pts.geometry.centroid\n",
        "amenities_pts = amenities_pts[amenities_pts.geometry.within(\n",
        "    boundary.geometry.iloc[0]\n",
        ")]\n"
      ],
      "metadata": {
        "id": "6xYHXChtnOYX"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(f\"The total amenities in the study area: {len(amenities_pts)}\")"
      ],
      "metadata": {
        "id": "7CDVEl7unszy"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Breaking down\n",
        "if \"amenity\" in amenities_pts.columns:\n",
        "  print(\"\\n --Amenity Breakdown--\")\n",
        "  counts = amenities_pts['amenity'].value_counts().head()\n",
        "  for cat, n in counts.items():\n",
        "    print(f\"{cat:25s} {n:>5d}\")"
      ],
      "metadata": {
        "id": "IunT1iTEn1Ph"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# SAVED AMENITEIS\n",
        "amenities_path = data_dir / \"amenities.gpkg\"\n",
        "\n",
        "# Drop the problematic column 'currency:ghs' before saving\n",
        "if 'currency:ghs' in amenities_pts.columns:\n",
        "    amenities_pts = amenities_pts.drop(columns=['currency:ghs'])\n",
        "\n",
        "amenities_pts.to_file(amenities_path, driver = 'GPKG')\n",
        "print(f\"Amenities saved: {amenities_path}\")"
      ],
      "metadata": {
        "id": "SfqMnrQAoYjw"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# LEISURE AND GREEN SPACE\n",
        "try:\n",
        "  leisure = ox.features_from_place(study_area, tags = leisure_tags)\n",
        "  leisure_polys = leisure[leisure.geometry.geom_type.isin(\n",
        "      ['Polygon', 'MultiPolygon']\n",
        "  )]\n",
        "  print(f\"Leisure Polygons found: {len(leisure_polys)}\")\n",
        "  leisure_path = data_dir / \"leisure.gpkg\"\n",
        "  leisure_polys.to_file(leisure_path, driver = 'GPKG')\n",
        "  print(f\"Leisure saved -> {leisure_path}\")\n",
        "\n",
        "except Exception as e:\n",
        "  print(f\"There is no leisure feature found or error {e}\")\n",
        "  leisure_polys = gpd.geoDataFrame()"
      ],
      "metadata": {
        "id": "Wq5ZZVOxpRC6"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# VISUALIZE POI MAP ON DARK BASEMAP\n",
        "# Colour palette for amenity categories\n",
        "category_colors = {\n",
        "    'hospital':         '#ff1744',\n",
        "    'clinic':           '#ff5252',\n",
        "    'pharmacy':         '#ff8a80',\n",
        "    'school':           '#448aff',\n",
        "    'university':       '#2962ff',\n",
        "    'library':          '#82b1ff',\n",
        "    'marketplace':      '#ffc400',\n",
        "    'bank':             '#69f0ae',\n",
        "    'atm':              '#b9f6ca',\n",
        "    'police':           '#e040fb',\n",
        "    'fire_station':     '#ea80fc',\n",
        "    'place_of_worship': '#b388ff',\n",
        "    'restaurant':       '#ff9100',\n",
        "    'fuel':             '#ffab40',\n",
        "}\n",
        "\n",
        "\n",
        "fig, ax = plt.subplots(1,1, figsize = (14, 14))\n",
        "fig.patch.set_facecolor(dark_bg)\n",
        "ax.set_facecolor(dark_bg)\n",
        "\n",
        "# Boundary Outline\n",
        "boundary.to_crs(crs_mercator).plot(\n",
        "    ax = ax,\n",
        "    facecolor='none',\n",
        "    edgecolor = 'white',\n",
        "    linewidth=2\n",
        ")\n",
        "\n",
        "# Amenity plotting\n",
        "if \"amenity\" in amenities_pts.columns:\n",
        "  legend_handles = []\n",
        "  for cat, color in category_colors.items():\n",
        "    subset = amenities_pts[amenities_pts['amenity'] == cat]\n",
        "    if len(subset) > 0:\n",
        "      subset.to_crs(crs_mercator).plot(\n",
        "          ax = ax, color = color, markersize = 12,\n",
        "          alpha = 0.8,\n",
        "          zorder = 5\n",
        "      )\n",
        "      legend_handles.append(\n",
        "          mpatches.Patch(color = color,\n",
        "                         label = f\"{cat} ({len(subset)})\")\n",
        "      )\n",
        "\n",
        "  # Move legend creation outside the loop\n",
        "  if legend_handles:\n",
        "      ax.legend(\n",
        "          handles = legend_handles, loc = 'lower right',\n",
        "          fontsize = 7,\n",
        "          facecolor = '#1a1a2e', edgecolor = 'white',\n",
        "          labelcolor = 'white', framealpha = 0.9,\n",
        "          ncols = 2\n",
        "      )\n",
        "\n",
        "  cx.add_basemap(ax, source = cx.providers.CartoDB.DarkMatter)\n",
        "  ax.set_axis_off()\n",
        "  ax.set_title(\n",
        "      f\"Points of Interest -- {study_area}\",\n",
        "      fontsize = 16, fontweight = 'bold',\n",
        "      color = 'white', pad = 20\n",
        "  )\n",
        "\n",
        "  fig.tight_layout()\n",
        "  fig.savefig(figures_dir / \"ch2_po1.png\", dpi = 130,\n",
        "            bbox_inches = 'tight',\n",
        "            facecolor = dark_bg  )\n",
        "\n",
        "  plt.show()"
      ],
      "metadata": {
        "id": "34gBjSzzutGM"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Interactive POI Map with Folium\n",
        "centroid = boundary.geometry.iloc[0].centroid\n",
        "m = folium.Map(\n",
        "    location = [centroid.y, centroid.x],\n",
        "    zoom_start=13,\n",
        "    titles = \"CartoDB dark_matater\"\n",
        ")\n",
        "# add boundary\n",
        "folium.GeoJson(\n",
        "    boundary.to_json(),\n",
        "    style_function= lambda x: {\n",
        "        'fillColor':'transparent', 'color':'#00e5ff', \"weight\":2\n",
        "    }\n",
        ").add_to(m)\n",
        "\n",
        "# Adding amenities\n",
        "sample = amenities_pts.head(500)\n",
        "for _, row in sample.iterrows():\n",
        "  cat = row.get('amenity', \"Unknown\")\n",
        "  name = row.get('name', cat)\n",
        "  color = 'red' if cat in ['hospital', 'clinic'] else \\\n",
        "  'blue' if cat in ['school', 'university'] else \\\n",
        "  'orange' if cat == 'marketplace' else 'gray'\n",
        "\n",
        "  folium.CircleMarker(\n",
        "      location = [row.geometry.y, row.geometry.x],\n",
        "      radius=4, color = color, fill =True,\n",
        "      popup=f'<b>{name}</b><br>{cat}',\n",
        "      tooltip=str(name),\n",
        "\n",
        "  ).add_to(m)\n",
        "\n",
        "# Save and display the map AFTER the loop has finished\n",
        "m.save(str(output_dir / 'ch2_poi_interactive.html'))\n",
        "m"
      ],
      "metadata": {
        "id": "LAdVAszQv2KW"
      },
      "execution_count": null,
      "outputs": []
    },
