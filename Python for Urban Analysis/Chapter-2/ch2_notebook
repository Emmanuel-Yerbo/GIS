        "    linewidth=2\n",
        ")\n",
        "\n",
        "# Amenity plotting\n",
        "if \"amenity\" in amenities_pts.columns:\n",
        "  legend_handles = []\n",
        "  for cat, color in category_colors.items():\n",
        "    subset = amenities_pts[amenities_pts['amenity'] == cat]\n",
        "    if len(subset) > 0:\n",
        "      subset.to_crs(crs_mercator).plot(\n",
