    {
      "cell_type": "code",
      "source": [
        "# VISUALIZE POI MAP ON DARK BASEMAP\n",
        "# Colour palette for amenity categories\n",
        "category_colors = {\n",
        "    'hospital':         '#ff1744',\n",
        "    'clinic':           '#ff5252',\n",
        "    'pharmacy':         '#ff8a80',\n",
        "    'school':           '#448aff',\n",
        "    'university':       '#2962ff',\n",
        "    'library':          '#82b1ff',\n",
        "    'marketplace':      '#ffc400',\n",
